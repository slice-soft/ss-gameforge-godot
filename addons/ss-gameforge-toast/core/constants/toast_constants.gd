extends Object
class_name ToastConstants

# Shared enums for toast styling and placement.
enum ToastStyle { INFO, SUCCESS, DANGER, CUSTOM, LOADER }

# Anchor positions where toast views can appear on screen.
enum ToastPosition {
	TOP_LEFT,
	TOP_CENTER,
	TOP_RIGHT,
	CENTER_LEFT,
	CENTER,
	CENTER_RIGHT,
	BOTTOM_LEFT,
	BOTTOM_CENTER,
	BOTTOM_RIGHT,
}
